#!/bin/sh
# RosterBot configure script
# Generates Makefile from Makefile.in with site-specific settings.

set -e

PACKAGE="rosterbot"
VERSION="1.0"
SRCDIR="$(cd "$(dirname "$0")" && pwd)"

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
DEFAULT_PREFIX="/usr/local/rosterbot"
DEFAULT_BINDIR=""          # $PREFIX/scripts
DEFAULT_LIBDIR=""          # $PREFIX/lib
DEFAULT_DBDIR=""           # $PREFIX/sql
DEFAULT_ETCDIR=""          # $PREFIX/etc
DEFAULT_LOGDIR="/var/log/rosterbot"
DEFAULT_SYSCONFDIR=""      # $PREFIX
DEFAULT_RUNUSER="rosterbot"
DEFAULT_RUNGROUP="rosterbot"
DEFAULT_LOGUSER=""         # ${RUNUSER}l  (daemontools convention)
DEFAULT_LOGGROUP=""        # same as LOGUSER
DEFAULT_PROCESS_MANAGER="auto"
DEFAULT_SERVICE_DIR="/service"   # daemontools service scan dir
DEFAULT_ADMIN_USERNAME=""
DEFAULT_ADMIN_ID=""
DEFAULT_PERL=""            # auto-detect
DEFAULT_SQLITE3=""         # auto-detect
DEFAULT_MEM_LIMIT="314572800"  # 300 MB softlimit for daemontools

PREFIX="$DEFAULT_PREFIX"
BINDIR=""
LIBDIR=""
DBDIR=""
ETCDIR=""
LOGDIR="$DEFAULT_LOGDIR"
SYSCONFDIR=""
RUNUSER="$DEFAULT_RUNUSER"
RUNGROUP="$DEFAULT_RUNGROUP"
LOGUSER=""
LOGGROUP=""
PROCESS_MANAGER="$DEFAULT_PROCESS_MANAGER"
SERVICE_DIR="$DEFAULT_SERVICE_DIR"
ADMIN_USERNAME="$DEFAULT_ADMIN_USERNAME"
ADMIN_ID="$DEFAULT_ADMIN_ID"
PERL="$DEFAULT_PERL"
SQLITE3="$DEFAULT_SQLITE3"
MEM_LIMIT="$DEFAULT_MEM_LIMIT"

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
    cat <<EOF
Usage: $0 [OPTION]...

Configure RosterBot for installation on this system.

Installation directories:
  --prefix=DIR           Root installation directory       [${DEFAULT_PREFIX}]
  --bindir=DIR           Scripts directory                 [\$PREFIX/scripts]
  --libdir=DIR           Perl library directory            [\$PREFIX/lib]
  --dbdir=DIR            Database directory                [\$PREFIX/sql]
  --etcdir=DIR           Config files directory            [\$PREFIX/etc]
  --sysconfdir=DIR       Configuration directory (passwd)  [\$PREFIX]
  --logdir=DIR           Log directory                     [${DEFAULT_LOGDIR}]

Process management:
  --process-manager=TYPE Process manager: systemd, daemontools, initd  [auto]
  --service-dir=DIR      Daemontools service scan directory [${DEFAULT_SERVICE_DIR}]

Runtime user/group:
  --user=USER            User to run RosterBot as          [${DEFAULT_RUNUSER}]
  --group=GROUP          Group to run RosterBot as         [${DEFAULT_RUNGROUP}]
  --log-user=USER        Daemontools log user              [\${USER}l]
  --log-group=GROUP      Daemontools log group             [same as --log-user]
  --mem-limit=BYTES      Memory soft limit (daemontools)   [${DEFAULT_MEM_LIMIT}]

Discord settings:
  --admin-username=NAME  Initial Discord admin username    [none]
  --admin-id=ID          Initial Discord admin user ID     [none]
                         Both --admin-username and --admin-id must be
                         specified together, or neither.

Optional tools:
  --perl=PATH            Path to perl interpreter          [auto-detect]
  --sqlite3=PATH         Path to sqlite3 binary            [auto-detect]

Other:
  --help                 Display this help and exit

Examples:
  $0 --prefix=/usr/local/rosterbot --process-manager=systemd \\
     --admin-username=alice --admin-id=123456789012345678

  $0 --prefix=/home/users/rosterbot \\
     --process-manager=daemontools --user=rosterbot --group=rosterbot \\
     --log-user=rosterbotl

Finding your Discord user ID:
  Enable Developer Mode in Discord (Settings > Advanced > Developer Mode),
  then right-click your username and select "Copy User ID".

EOF
}

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------
for arg in "$@"; do
    case "$arg" in
        --help|-h)          usage; exit 0 ;;
        --prefix=*)         PREFIX="${arg#*=}" ;;
        --bindir=*)         BINDIR="${arg#*=}" ;;
        --libdir=*)         LIBDIR="${arg#*=}" ;;
        --dbdir=*)          DBDIR="${arg#*=}" ;;
        --etcdir=*)         ETCDIR="${arg#*=}" ;;
        --sysconfdir=*)     SYSCONFDIR="${arg#*=}" ;;
        --logdir=*)         LOGDIR="${arg#*=}" ;;
        --process-manager=*)PROCESS_MANAGER="${arg#*=}" ;;
        --service-dir=*)    SERVICE_DIR="${arg#*=}" ;;
        --user=*)           RUNUSER="${arg#*=}" ;;
        --group=*)          RUNGROUP="${arg#*=}" ;;
        --log-user=*)       LOGUSER="${arg#*=}" ;;
        --log-group=*)      LOGGROUP="${arg#*=}" ;;
        --mem-limit=*)      MEM_LIMIT="${arg#*=}" ;;
        --admin-username=*) ADMIN_USERNAME="${arg#*=}" ;;
        --admin-id=*)       ADMIN_ID="${arg#*=}" ;;
        --perl=*)           PERL="${arg#*=}" ;;
        --sqlite3=*)        SQLITE3="${arg#*=}" ;;
        --*)
            echo "ERROR: Unknown option: $arg" >&2
            echo "Run '$0 --help' for usage." >&2
            exit 1
            ;;
    esac
done

# ---------------------------------------------------------------------------
# Resolve derived defaults
# ---------------------------------------------------------------------------
: "${BINDIR:=${PREFIX}/scripts}"
: "${LIBDIR:=${PREFIX}/lib}"
: "${DBDIR:=${PREFIX}/sql}"
: "${ETCDIR:=${PREFIX}/etc}"
: "${SYSCONFDIR:=${PREFIX}}"

DBFILE="${DBDIR}/rosterbot.db"
PASSWDFILE="${ETCDIR}/.passwd"
MSGFILE="${ETCDIR}/contact_message.txt"

# Daemontools log user convention: append 'l' to run user
if [ -z "$LOGUSER" ]; then
    LOGUSER="${RUNUSER}l"
fi
: "${LOGGROUP:=${LOGUSER}}"

# ---------------------------------------------------------------------------
# Validate admin args: require both or neither
# ---------------------------------------------------------------------------
if [ -n "$ADMIN_USERNAME" ] && [ -z "$ADMIN_ID" ]; then
    echo "ERROR: --admin-username requires --admin-id to be set as well." >&2
    exit 1
fi
if [ -n "$ADMIN_ID" ] && [ -z "$ADMIN_USERNAME" ]; then
    echo "ERROR: --admin-id requires --admin-username to be set as well." >&2
    exit 1
fi

if [ "$RUNUSER" = "root" ] || [ "$RUNGROUP" = "root" ]; then
    echo "WARNING: Running RosterBot as root is strongly discouraged." >&2
    echo "         Use --user and --group to specify a non-root account." >&2
fi

# ---------------------------------------------------------------------------
# Detect tools
# ---------------------------------------------------------------------------
check_tool() {
    local name="$1"
    local var="$2"
    local paths="$3"

    printf "checking for %s... " "$name"
    eval "current=\$$var"
    if [ -n "$current" ]; then
        if [ -x "$current" ]; then
            echo "$current"
            return 0
        else
            echo "not found at $current" >&2
            return 1
        fi
    fi
    for p in $paths; do
        if [ -x "$p" ]; then
            eval "$var=$p"
            echo "$p"
            return 0
        fi
    done
    echo "not found"
    return 1
}

MISSING_TOOLS=""

# Find perl
printf "checking for perl... "
if [ -z "$PERL" ]; then
    PERL=$(command -v perl 2>/dev/null || true)
fi
if [ -z "$PERL" ] || [ ! -x "$PERL" ]; then
    echo "not found"
    MISSING_TOOLS="$MISSING_TOOLS perl"
else
    PERL_VER=$("$PERL" -e 'printf "%vd", $^V')
    echo "$PERL ($PERL_VER)"
    # Check version >= 5.020
    PERL_OK=$("$PERL" -e 'print(($^V ge v5.20.0) ? "yes" : "no")')
    if [ "$PERL_OK" != "yes" ]; then
        echo "ERROR: Perl 5.020 or newer is required (found $PERL_VER)." >&2
        MISSING_TOOLS="$MISSING_TOOLS perl>=5.020"
    fi
fi

# Find sqlite3
printf "checking for sqlite3... "
if [ -z "$SQLITE3" ]; then
    SQLITE3=$(command -v sqlite3 2>/dev/null || true)
fi
if [ -z "$SQLITE3" ] || [ ! -x "$SQLITE3" ]; then
    echo "not found"
    MISSING_TOOLS="$MISSING_TOOLS sqlite3"
else
    echo "$SQLITE3"
fi

# ---------------------------------------------------------------------------
# Check Perl modules
# ---------------------------------------------------------------------------
MISSING_MODULES=""
check_perl_module() {
    local mod="$1"
    local pkg="$2"
    printf "checking for perl module %s... " "$mod"
    if "$PERL" -e "use $mod; 1" 2>/dev/null; then
        echo "yes"
    else
        echo "no"
        MISSING_MODULES="$MISSING_MODULES $mod"
    fi
}

if [ -x "$PERL" ]; then
    check_perl_module "DBI"            "libdbi-perl"
    check_perl_module "DBD::SQLite"    "libdbd-sqlite3-perl"
    check_perl_module "Mojo::UserAgent" "libmojolicious-perl"
    check_perl_module "Mojo::IOLoop"   "libmojolicious-perl"
    check_perl_module "Mojo::JSON"     "libmojolicious-perl"
    check_perl_module "Mail::VRFY"     "libmail-vrfy-perl"
    check_perl_module "Date::Parse"    "libtimedate-perl"
    check_perl_module "Getopt::Long"   "(core)"
    check_perl_module "Exporter"       "(core)"
fi

# ---------------------------------------------------------------------------
# Detect process manager
# ---------------------------------------------------------------------------
printf "checking for process manager... "

if [ "$PROCESS_MANAGER" = "auto" ]; then
    if command -v systemctl >/dev/null 2>&1 && systemctl --version >/dev/null 2>&1; then
        PROCESS_MANAGER="systemd"
    elif command -v svscan >/dev/null 2>&1 || command -v supervise >/dev/null 2>&1; then
        PROCESS_MANAGER="daemontools"
    elif [ -d /etc/init.d ]; then
        PROCESS_MANAGER="initd"
    else
        PROCESS_MANAGER=""
    fi
fi

case "$PROCESS_MANAGER" in
    systemd)
        echo "systemd"
        SYSTEMCTL=$(command -v systemctl 2>/dev/null || true)
        if [ -z "$SYSTEMCTL" ]; then
            echo "ERROR: systemctl not found but --process-manager=systemd requested." >&2
            MISSING_TOOLS="$MISSING_TOOLS systemctl"
        fi
        SYSTEMD_UNIT_DIR="/etc/systemd/system"
        ;;
    daemontools)
        echo "daemontools"
        SOFTLIMIT=$(command -v softlimit 2>/dev/null || true)
        SETUIDGID=$(command -v setuidgid 2>/dev/null || true)
        MULTILOG=$(command -v multilog 2>/dev/null || true)
        SVSCANBOOT=$(command -v svscanboot 2>/dev/null || true)
        for tool in softlimit setuidgid multilog; do
            eval "tp=\$$tool"
            if [ -z "$tp" ]; then
                # try /usr/local/bin
                if [ -x "/usr/local/bin/$tool" ]; then
                    eval "$tool=/usr/local/bin/$tool"
                    tp="/usr/local/bin/$tool"
                else
                    echo "WARNING: daemontools tool '$tool' not found." >&2
                fi
            fi
        done
        : "${SOFTLIMIT:=/usr/local/bin/softlimit}"
        : "${SETUIDGID:=/usr/local/bin/setuidgid}"
        : "${MULTILOG:=/usr/local/bin/multilog}"
        ;;
    initd)
        echo "init.d"
        ;;
    "")
        echo "none detected"
        echo ""
        echo "ERROR: Could not detect a process manager." >&2
        echo "       Re-run configure with --process-manager=systemd|daemontools|initd" >&2
        exit 1
        ;;
    *)
        echo "ERROR: Unknown process manager '$PROCESS_MANAGER'." >&2
        echo "       Valid choices: systemd, daemontools, initd" >&2
        exit 1
        ;;
esac

# ---------------------------------------------------------------------------
# Report missing deps
# ---------------------------------------------------------------------------
if [ -n "$MISSING_MODULES" ]; then
    echo ""
    echo "ERROR: Missing Perl module(s):$MISSING_MODULES" >&2
    echo "       Run 'scripts/install-deps.sh' to install dependencies." >&2
    echo "       Then re-run configure." >&2
    exit 1
fi

if [ -n "$MISSING_TOOLS" ]; then
    echo ""
    echo "ERROR: Missing required tool(s):$MISSING_TOOLS" >&2
    echo "       Run 'scripts/install-deps.sh' to install dependencies." >&2
    echo "       Then re-run configure." >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Generate Makefile from Makefile.in
# ---------------------------------------------------------------------------
echo ""
echo "Generating Makefile..."

if [ ! -f "${SRCDIR}/Makefile.in" ]; then
    echo "ERROR: Makefile.in not found in $SRCDIR" >&2
    exit 1
fi

sed \
    -e "s|%SRCDIR%|${SRCDIR}|g" \
    -e "s|%PREFIX%|${PREFIX}|g" \
    -e "s|%BINDIR%|${BINDIR}|g" \
    -e "s|%LIBDIR%|${LIBDIR}|g" \
    -e "s|%DBDIR%|${DBDIR}|g" \
    -e "s|%DBFILE%|${DBFILE}|g" \
    -e "s|%ETCDIR%|${ETCDIR}|g" \
    -e "s|%MSGFILE%|${MSGFILE}|g" \
    -e "s|%LOGDIR%|${LOGDIR}|g" \
    -e "s|%SYSCONFDIR%|${SYSCONFDIR}|g" \
    -e "s|%PASSWDFILE%|${PASSWDFILE}|g" \
    -e "s|%RUNUSER%|${RUNUSER}|g" \
    -e "s|%RUNGROUP%|${RUNGROUP}|g" \
    -e "s|%LOGUSER%|${LOGUSER}|g" \
    -e "s|%LOGGROUP%|${LOGGROUP}|g" \
    -e "s|%MEM_LIMIT%|${MEM_LIMIT}|g" \
    -e "s|%PROCESS_MANAGER%|${PROCESS_MANAGER}|g" \
    -e "s|%SERVICE_DIR%|${SERVICE_DIR}|g" \
    -e "s|%ADMIN_USERNAME%|${ADMIN_USERNAME}|g" \
    -e "s|%ADMIN_ID%|${ADMIN_ID}|g" \
    -e "s|%PERL%|${PERL}|g" \
    -e "s|%SQLITE3%|${SQLITE3}|g" \
    -e "s|%SOFTLIMIT%|${SOFTLIMIT:-/usr/local/bin/softlimit}|g" \
    -e "s|%SETUIDGID%|${SETUIDGID:-/usr/local/bin/setuidgid}|g" \
    -e "s|%MULTILOG%|${MULTILOG:-/usr/local/bin/multilog}|g" \
    -e "s|%SYSTEMD_UNIT_DIR%|${SYSTEMD_UNIT_DIR:-/etc/systemd/system}|g" \
    "${SRCDIR}/Makefile.in" > "${SRCDIR}/Makefile"

# ---------------------------------------------------------------------------
# Write config.status
# ---------------------------------------------------------------------------
cat > "${SRCDIR}/config.status" <<CFGEOF
# RosterBot configuration status
# Generated by configure on $(date)
# Re-run: $0 $@

SRCDIR="${SRCDIR}"
PREFIX="${PREFIX}"
BINDIR="${BINDIR}"
LIBDIR="${LIBDIR}"
DBDIR="${DBDIR}"
DBFILE="${DBFILE}"
ETCDIR="${ETCDIR}"
MSGFILE="${MSGFILE}"
LOGDIR="${LOGDIR}"
SYSCONFDIR="${SYSCONFDIR}"
PASSWDFILE="${PASSWDFILE}"
RUNUSER="${RUNUSER}"
RUNGROUP="${RUNGROUP}"
LOGUSER="${LOGUSER}"
LOGGROUP="${LOGGROUP}"
MEM_LIMIT="${MEM_LIMIT}"
PROCESS_MANAGER="${PROCESS_MANAGER}"
SERVICE_DIR="${SERVICE_DIR}"
ADMIN_USERNAME="${ADMIN_USERNAME}"
ADMIN_ID="${ADMIN_ID}"
PERL="${PERL}"
SQLITE3="${SQLITE3}"
CFGEOF

# ---------------------------------------------------------------------------
# Print summary
# ---------------------------------------------------------------------------
cat <<SUMMARY

Configuration summary:
  Source directory:    ${SRCDIR}
  Install prefix:      ${PREFIX}
  Scripts directory:   ${BINDIR}
  Perl lib directory:  ${LIBDIR}
  Database directory:  ${DBDIR}
  Database file:       ${DBFILE}
  Config/passwd file:  ${PASSWDFILE}
  Contact message:     ${MSGFILE}
  Log directory:       ${LOGDIR}
  Process manager:     ${PROCESS_MANAGER}
  Run as user:         ${RUNUSER}:${RUNGROUP}
  Perl:                ${PERL}
  sqlite3:             ${SQLITE3}
SUMMARY

if [ -n "$ADMIN_ID" ]; then
    echo "  Initial admin:       ${ADMIN_USERNAME} (${ADMIN_ID})"
else
    echo "  Initial admin:       (none - set via sqlite3 after install)"
fi

if [ "$PROCESS_MANAGER" = "daemontools" ]; then
    echo "  Log user:            ${LOGUSER}:${LOGGROUP}"
    echo "  Service directory:   ${SERVICE_DIR}/rosterbot"
fi
if [ "$PROCESS_MANAGER" = "systemd" ]; then
    echo "  Systemd unit dir:    ${SYSTEMD_UNIT_DIR:-/etc/systemd/system}"
fi

cat <<SUMMARY2

Now run:
  make           # syntax-check Perl source files
  make install   # install (requires root)

SUMMARY2
