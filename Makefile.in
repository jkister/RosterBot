# RosterBot Makefile
# Generated by configure -- do not edit by hand.
# Re-run ./configure to regenerate.

SRCDIR          = %SRCDIR%
BUILDDIR        = %SRCDIR%/build
PREFIX          = %PREFIX%
BINDIR          = %BINDIR%
LIBDIR          = %LIBDIR%
DBDIR           = %DBDIR%
DBFILE          = %DBFILE%
ETCDIR          = %ETCDIR%
MSGFILE         = %MSGFILE%
LOGDIR          = %LOGDIR%
SYSCONFDIR      = %SYSCONFDIR%
PASSWDFILE      = %PASSWDFILE%
RUNUSER         = %RUNUSER%
RUNGROUP        = %RUNGROUP%
LOGUSER         = %LOGUSER%
LOGGROUP        = %LOGGROUP%
MEM_LIMIT       = %MEM_LIMIT%
PROCESS_MANAGER = %PROCESS_MANAGER%
SERVICE_DIR     = %SERVICE_DIR%
ADMIN_USERNAME  = %ADMIN_USERNAME%
ADMIN_ID        = %ADMIN_ID%
PERL            = %PERL%
SQLITE3         = %SQLITE3%
SOFTLIMIT       = %SOFTLIMIT%
SETUIDGID       = %SETUIDGID%
MULTILOG        = %MULTILOG%
SYSTEMD_UNIT_DIR = %SYSTEMD_UNIT_DIR%

BUILD_SCRIPTS = \
	$(BUILDDIR)/scripts/rosterbot.pl \
	$(BUILDDIR)/scripts/export-users.pl \
	$(BUILDDIR)/etc/rosterbot.conf

BUILD_LIBS = \
	$(BUILDDIR)/lib/RosterBot/Database.pm \
	$(BUILDDIR)/lib/RosterBot/Discord.pm \
	$(BUILDDIR)/lib/RosterBot/Commands.pm \
	$(BUILDDIR)/lib/RosterBot/Contact.pm \
	$(BUILDDIR)/lib/RosterBot/Utils.pm

BUILD_SERVICE_daemontools = \
	$(BUILDDIR)/supervise/run \
	$(BUILDDIR)/supervise/log/run

BUILD_SERVICE_systemd = \
	$(BUILDDIR)/systemd/rosterbot.service

BUILD_SERVICE_initd = \
	$(BUILDDIR)/init.d/rosterbot \
	$(BUILDDIR)/logrotate.d/rosterbot

BUILD_FILES = $(BUILD_SCRIPTS) $(BUILD_LIBS) $(BUILD_SERVICE_$(PROCESS_MANAGER))

.PHONY: all build test install install-dirs install-user install-files \
        install-db install-service install-systemd install-daemontools \
        install-initd install-start uninstall clean distclean

# ---------------------------------------------------------------------------
# Default target: build processed files into build/
# ---------------------------------------------------------------------------
all: build

build: $(BUILD_FILES)

$(BUILDDIR)/scripts/rosterbot.pl: $(SRCDIR)/scripts/rosterbot.pl
	@mkdir -p $(BUILDDIR)/scripts
	sed \
		-e 's|@LIBDIR@|$(LIBDIR)|g' \
		-e 's|@ETCDIR@|$(ETCDIR)|g' \
		$< > $@
	chmod 0755 $@

$(BUILDDIR)/scripts/export-users.pl: $(SRCDIR)/scripts/export-users.pl
	@mkdir -p $(BUILDDIR)/scripts
	sed -e "s|@DBFILE@|$(DBFILE)|g" $< > $@
	chmod 0755 $@

$(BUILDDIR)/etc/rosterbot.conf: $(SRCDIR)/in/rosterbot.conf.in
	@mkdir -p $(BUILDDIR)/etc
	sed -e "s|@ETCDIR@|$(ETCDIR)|g" $< > $@

$(BUILDDIR)/lib/RosterBot/Discord.pm: $(SRCDIR)/lib/RosterBot/Discord.pm
	@mkdir -p $(BUILDDIR)/lib/RosterBot
	sed \
		-e "s|@DBFILE@|$(DBFILE)|g" \
		-e "s|@PASSWDFILE@|$(PASSWDFILE)|g" \
		$< > $@
	chmod 0644 $@

$(BUILDDIR)/lib/RosterBot/Contact.pm: $(SRCDIR)/lib/RosterBot/Contact.pm
	@mkdir -p $(BUILDDIR)/lib/RosterBot
	sed -e "s|@MSGFILE@|$(MSGFILE)|g" $< > $@
	chmod 0644 $@

$(BUILDDIR)/lib/RosterBot/%.pm: $(SRCDIR)/lib/RosterBot/%.pm
	@mkdir -p $(BUILDDIR)/lib/RosterBot
	install -m 0644 $< $@

$(BUILDDIR)/supervise/run: $(SRCDIR)/in/supervise/run.in
	@mkdir -p $(BUILDDIR)/supervise
	sed \
		-e "s|@SOFTLIMIT@|$(SOFTLIMIT)|g" \
		-e "s|@SETUIDGID@|$(SETUIDGID)|g" \
		-e "s|@RUNUSER@|$(RUNUSER)|g" \
		-e "s|@PREFIX@|$(PREFIX)|g" \
		-e "s|@BINDIR@|$(BINDIR)|g" \
		-e "s|@PERL@|$(PERL)|g" \
		-e "s|@MEM_LIMIT@|$(MEM_LIMIT)|g" \
		$< > $@
	chmod 0755 $@

$(BUILDDIR)/supervise/log/run: $(SRCDIR)/in/supervise/log/run.in
	@mkdir -p $(BUILDDIR)/supervise/log
	sed \
		-e "s|@SETUIDGID@|$(SETUIDGID)|g" \
		-e "s|@MULTILOG@|$(MULTILOG)|g" \
		-e "s|@LOGUSER@|$(LOGUSER)|g" \
		-e "s|@LOGDIR@|$(LOGDIR)|g" \
		$< > $@
	chmod 0755 $@

$(BUILDDIR)/systemd/rosterbot.service: $(SRCDIR)/in/systemd/rosterbot.service.in
	@mkdir -p $(BUILDDIR)/systemd
	sed \
		-e "s|@PERL@|$(PERL)|g" \
		-e "s|@BINDIR@|$(BINDIR)|g" \
		-e "s|@PREFIX@|$(PREFIX)|g" \
		-e "s|@RUNUSER@|$(RUNUSER)|g" \
		-e "s|@RUNGROUP@|$(RUNGROUP)|g" \
		-e "s|@MEM_LIMIT@|$(MEM_LIMIT)|g" \
		$< > $@

$(BUILDDIR)/init.d/rosterbot: $(SRCDIR)/in/init.d/rosterbot.in
	@mkdir -p $(BUILDDIR)/init.d
	sed \
		-e "s|@PERL@|$(PERL)|g" \
		-e "s|@BINDIR@|$(BINDIR)|g" \
		-e "s|@PREFIX@|$(PREFIX)|g" \
		-e "s|@RUNUSER@|$(RUNUSER)|g" \
		-e "s|@RUNGROUP@|$(RUNGROUP)|g" \
		-e "s|@LOGDIR@|$(LOGDIR)|g" \
		$< > $@
	chmod 0755 $@

$(BUILDDIR)/logrotate.d/rosterbot: $(SRCDIR)/in/logrotate.d/rosterbot.in
	@mkdir -p $(BUILDDIR)/logrotate.d
	sed \
		-e "s|@LOGDIR@|$(LOGDIR)|g" \
		-e "s|@RUNUSER@|$(RUNUSER)|g" \
		-e "s|@RUNGROUP@|$(RUNGROUP)|g" \
		$< > $@

# ---------------------------------------------------------------------------
# Test: syntax-check the built files
# ---------------------------------------------------------------------------
test: build
	@echo "Syntax-checking built Perl files..."
	@failed=0; \
	for f in $(BUILD_SCRIPTS) $(BUILD_LIBS); do \
		printf "  %-60s " "$$f"; \
		if $(PERL) -I$(BUILDDIR)/lib -c "$$f" 2>/dev/null; then \
			echo "OK"; \
		else \
			$(PERL) -I$(BUILDDIR)/lib -c "$$f" 2>&1 | head -3; \
			failed=$$((failed+1)); \
		fi; \
	done; \
	if [ $$failed -ne 0 ]; then \
		echo "$$failed file(s) failed syntax check."; exit 1; \
	fi
	@echo "All files OK."

# ---------------------------------------------------------------------------
# Install
# ---------------------------------------------------------------------------
install: build install-dirs install-user install-files install-db \
         install-service install-start
	@echo ""
	@echo "RosterBot installation complete."
	@echo ""
	@step=1; \
	echo "Next steps:"; \
	if grep -q "replace_with_your_token_here" "$(PASSWDFILE)" 2>/dev/null; then \
		echo "  $$step. Edit $(PASSWDFILE) and set your Discord bot token:"; \
		echo "       DISCORD_TOKEN=your.token.here"; \
		step=$$((step+1)); \
	fi; \
	echo "  $$step. Customize the contact request message (optional):"; \
	echo "       $(MSGFILE)"; \
	step=$$((step+1)); \
	echo "  $$step. Ensure the service is running:"; \
	if [ "$(PROCESS_MANAGER)" = "systemd" ]; then \
		echo "       systemctl status rosterbot"; \
	elif [ "$(PROCESS_MANAGER)" = "daemontools" ]; then \
		echo "       svstat $(SERVICE_DIR)/rosterbot"; \
	else \
		echo "       /etc/init.d/rosterbot status"; \
	fi; \
	step=$$((step+1)); \
	if [ -z "$(ADMIN_ID)" ] && [ -f "$(DBFILE)" ]; then \
		admin_count=$$($(SQLITE3) $(DBFILE) "SELECT COUNT(*) FROM admins;" 2>/dev/null || echo 0); \
		if [ "$$admin_count" -eq 0 ]; then \
			echo ""; \
			echo "  $$step. Add an initial admin via sqlite3 (bot has no admins yet):"; \
			echo "       sqlite3 $(DBFILE) \\"; \
			echo "         \"INSERT OR IGNORE INTO users (user_id, username, contact_status)"; \
			echo "          VALUES ('YOUR_DISCORD_ID', 'yourusername', 'provided');"; \
			echo "          INSERT OR IGNORE INTO admins (user_id, username, granted_by, granted_at)"; \
			echo "          VALUES ('YOUR_DISCORD_ID', 'yourusername', 'YOUR_DISCORD_ID', datetime('now'));\""; \
		fi; \
	fi

_check-root:
	@if [ "$$(id -u)" -ne 0 ]; then \
		echo "ERROR: This step requires root." >&2; \
		exit 1; \
	fi

install-dirs:
	@echo "Creating directories..."
	install -d -m 0755 $(PREFIX)
	install -d -m 0755 $(BINDIR)
	install -d -m 0755 $(LIBDIR)/RosterBot
	install -d -m 0750 $(DBDIR)
	install -d -m 0755 $(ETCDIR)
	install -d -m 0755 $(LOGDIR)
	install -d -m 0755 $(SYSCONFDIR)

install-user:
	@echo "Creating system user/group..."
	@if ! getent group $(RUNGROUP) >/dev/null 2>&1; then \
		if [ "$$(id -u)" -ne 0 ]; then echo "ERROR: group $(RUNGROUP) does not exist and root is required to create it." >&2; exit 1; fi; \
		groupadd --system $(RUNGROUP); \
		echo "  Created group: $(RUNGROUP)"; \
	else \
		echo "  Group already exists: $(RUNGROUP)"; \
	fi
	@if ! getent passwd $(RUNUSER) >/dev/null 2>&1; then \
		if [ "$$(id -u)" -ne 0 ]; then echo "ERROR: user $(RUNUSER) does not exist and root is required to create it." >&2; exit 1; fi; \
		useradd --system --no-create-home \
			--home-dir $(PREFIX) \
			--shell /usr/sbin/nologin \
			--gid $(RUNGROUP) \
			$(RUNUSER); \
		echo "  Created user: $(RUNUSER)"; \
	else \
		echo "  User already exists: $(RUNUSER)"; \
	fi
	@if [ "$(PROCESS_MANAGER)" = "daemontools" ]; then \
		if ! getent group $(LOGGROUP) >/dev/null 2>&1; then \
			if [ "$$(id -u)" -ne 0 ]; then echo "ERROR: group $(LOGGROUP) does not exist and root is required to create it." >&2; exit 1; fi; \
			groupadd --system $(LOGGROUP); \
			echo "  Created group: $(LOGGROUP)"; \
		else \
			echo "  Group already exists: $(LOGGROUP)"; \
		fi; \
		if ! getent passwd $(LOGUSER) >/dev/null 2>&1; then \
			if [ "$$(id -u)" -ne 0 ]; then echo "ERROR: user $(LOGUSER) does not exist and root is required to create it." >&2; exit 1; fi; \
			useradd --system --no-create-home \
				--home-dir /nonexistent \
				--shell /usr/sbin/nologin \
				--gid $(LOGGROUP) \
				$(LOGUSER); \
			echo "  Created user: $(LOGUSER)"; \
		else \
			echo "  User already exists: $(LOGUSER)"; \
		fi; \
	fi

install-files:
	@echo "Installing files..."
	install -m 0755 $(BUILDDIR)/scripts/rosterbot.pl  $(BINDIR)/rosterbot.pl
	install -m 0755 $(BUILDDIR)/scripts/export-users.pl $(BINDIR)/export-users.pl
	install -m 0644 $(BUILDDIR)/lib/RosterBot/Database.pm $(LIBDIR)/RosterBot/Database.pm
	install -m 0644 $(BUILDDIR)/lib/RosterBot/Discord.pm  $(LIBDIR)/RosterBot/Discord.pm
	install -m 0644 $(BUILDDIR)/lib/RosterBot/Commands.pm $(LIBDIR)/RosterBot/Commands.pm
	install -m 0644 $(BUILDDIR)/lib/RosterBot/Contact.pm  $(LIBDIR)/RosterBot/Contact.pm
	install -m 0644 $(BUILDDIR)/lib/RosterBot/Utils.pm    $(LIBDIR)/RosterBot/Utils.pm
	@if [ ! -f "$(MSGFILE)" ]; then \
		install -m 0640 $(SRCDIR)/in/contact_message.txt.in $(MSGFILE); \
		echo "  Created $(MSGFILE) -- edit to customize the contact request message."; \
	else \
		echo "  $(MSGFILE) already exists, leaving unchanged."; \
	fi
	@if [ ! -f "$(ETCDIR)/rosterbot.conf" ]; then \
		install -m 0640 $(BUILDDIR)/etc/rosterbot.conf $(ETCDIR)/rosterbot.conf; \
		echo "  Created $(ETCDIR)/rosterbot.conf -- edit to set runtime options."; \
	else \
		echo "  $(ETCDIR)/rosterbot.conf already exists, leaving unchanged."; \
	fi
	@if [ ! -f "$(PASSWDFILE)" ]; then \
		echo "# RosterBot credentials" > $(PASSWDFILE); \
		echo "DISCORD_TOKEN=replace_with_your_token_here" >> $(PASSWDFILE); \
		echo "  Created $(PASSWDFILE) -- set your Discord token before starting!"; \
	else \
		echo "  $(PASSWDFILE) already exists, leaving unchanged."; \
	fi
	chown -R $(RUNUSER):$(RUNGROUP) $(PREFIX)
	@if [ "$(PROCESS_MANAGER)" = "daemontools" ]; then \
		chown -R $(LOGUSER):$(LOGGROUP) $(LOGDIR); \
	else \
		chown -R $(RUNUSER):$(RUNGROUP) $(LOGDIR); \
	fi
	chmod 0644 $(PASSWDFILE)

install-db:
	@echo "Initializing database..."
	@if [ ! -f "$(DBFILE)" ]; then \
		$(SQLITE3) $(DBFILE) < $(SRCDIR)/sql/rosterbot.sql; \
		echo "  Database created: $(DBFILE)"; \
	else \
		echo "  Database already exists, applying schema (safe -- uses IF NOT EXISTS)..."; \
		$(SQLITE3) $(DBFILE) < $(SRCDIR)/sql/rosterbot.sql; \
	fi
	@if [ -n "$(ADMIN_ID)" ]; then \
		echo "  Seeding initial admin: $(ADMIN_USERNAME) ($(ADMIN_ID))"; \
		$(SQLITE3) $(DBFILE) \
			"INSERT OR IGNORE INTO users (user_id, username, contact_status) \
			 VALUES ('$(ADMIN_ID)', '$(ADMIN_USERNAME)', 'provided'); \
			 INSERT OR IGNORE INTO admins (user_id, username, granted_by, granted_at) \
			 VALUES ('$(ADMIN_ID)', '$(ADMIN_USERNAME)', '$(ADMIN_ID)', datetime('now'));"; \
	fi
	chown $(RUNUSER):$(RUNGROUP) $(DBFILE)
	chmod 0640 $(DBFILE)

install-service: install-$(PROCESS_MANAGER)

install-systemd: _check-root
	@echo "Installing systemd unit..."
	install -m 0644 $(BUILDDIR)/systemd/rosterbot.service $(SYSTEMD_UNIT_DIR)/rosterbot.service
	systemctl daemon-reload
	systemctl enable rosterbot
	@echo "  Systemd unit installed and enabled."

install-daemontools:
	@echo "Installing daemontools service..."
	install -d -m 0755 $(PREFIX)/supervise
	install -d -m 0755 $(PREFIX)/supervise/log
	install -m 0755 $(BUILDDIR)/supervise/run     $(PREFIX)/supervise/run
	install -m 0755 $(BUILDDIR)/supervise/log/run $(PREFIX)/supervise/log/run
	chown -R $(RUNUSER):$(RUNGROUP) $(PREFIX)/supervise
	@if [ -d "$(SERVICE_DIR)" ]; then \
		ln -sfn $(PREFIX)/supervise $(SERVICE_DIR)/rosterbot; \
		echo "  Linked $(SERVICE_DIR)/rosterbot -> $(PREFIX)/supervise"; \
	else \
		echo "WARNING: Service directory $(SERVICE_DIR) not found."; \
		echo "         Manually link: ln -s $(PREFIX)/supervise $(SERVICE_DIR)/rosterbot"; \
	fi

install-initd: _check-root
	@echo "Installing init.d script..."
	install -m 0755 $(BUILDDIR)/init.d/rosterbot /etc/init.d/rosterbot
	@if command -v update-rc.d >/dev/null 2>&1; then \
		update-rc.d rosterbot defaults; \
	elif command -v chkconfig >/dev/null 2>&1; then \
		chkconfig --add rosterbot; \
	fi
	install -m 0644 $(BUILDDIR)/logrotate.d/rosterbot /etc/logrotate.d/rosterbot
	@echo "  init.d script and logrotate config installed."

install-start:
	@echo "Starting RosterBot..."
	@if [ "$(PROCESS_MANAGER)" = "systemd" ]; then \
		systemctl restart rosterbot; \
		sleep 2; \
		systemctl is-active rosterbot && echo "  RosterBot is running." \
			|| echo "  WARNING: RosterBot may not have started. Check: journalctl -u rosterbot"; \
	elif [ "$(PROCESS_MANAGER)" = "daemontools" ]; then \
		if [ -L "$(SERVICE_DIR)/rosterbot" ]; then \
			svc -u $(SERVICE_DIR)/rosterbot 2>/dev/null || true; \
			sleep 2; \
			svstat $(SERVICE_DIR)/rosterbot || true; \
		else \
			echo "  WARNING: $(SERVICE_DIR)/rosterbot symlink missing, cannot start automatically."; \
		fi; \
	elif [ "$(PROCESS_MANAGER)" = "initd" ]; then \
		/etc/init.d/rosterbot restart || true; \
	fi

# ---------------------------------------------------------------------------
# Uninstall
# ---------------------------------------------------------------------------
uninstall:
	@echo "Stopping and removing RosterBot..."
	@if [ "$(PROCESS_MANAGER)" = "systemd" ]; then \
		systemctl stop rosterbot 2>/dev/null || true; \
		systemctl disable rosterbot 2>/dev/null || true; \
		rm -f $(SYSTEMD_UNIT_DIR)/rosterbot.service; \
		systemctl daemon-reload; \
	elif [ "$(PROCESS_MANAGER)" = "daemontools" ]; then \
		svc -d $(SERVICE_DIR)/rosterbot 2>/dev/null || true; \
		rm -f $(SERVICE_DIR)/rosterbot; \
	elif [ "$(PROCESS_MANAGER)" = "initd" ]; then \
		/etc/init.d/rosterbot stop 2>/dev/null || true; \
		rm -f /etc/init.d/rosterbot; \
	fi
	@echo "Removing installed files (database and passwd file preserved)..."
	rm -f $(BINDIR)/rosterbot.pl $(BINDIR)/export-users.pl
	rm -f $(LIBDIR)/RosterBot/Database.pm $(LIBDIR)/RosterBot/Discord.pm
	rm -f $(LIBDIR)/RosterBot/Commands.pm $(LIBDIR)/RosterBot/Contact.pm
	rm -f $(LIBDIR)/RosterBot/Utils.pm
	@echo "NOTE: $(DBFILE) and $(PASSWDFILE) were preserved."
	@echo "      Remove manually if desired."

# ---------------------------------------------------------------------------
# Housekeeping
# ---------------------------------------------------------------------------
clean:
	rm -rf $(BUILDDIR)

distclean: clean
	rm -f Makefile config.status
